# Copy to .env (or just export these) to enable live Claude generation.
# Get a key at https://console.anthropic.com/

ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional overrides:
# JARVIS_MODEL=claude-opus-4-8
# PORT=8000

# ── Human-level DIVA voice (ElevenLabs) ──────────────────────────────
# Get a key at https://elevenlabs.io/  → Profile → API key.
# With this set, DIVA speaks with a real ElevenLabs voice (served via the
# proxy so the key stays on the server). Without it, the app uses the
# browser's built-in British voice automatically.
# ELEVENLABS_API_KEY=sk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# ELEVENLABS_VOICE_ID=Xb7hH8MSUJpSbSDYk0k2   # "Alice" — British female (default)
# ELEVENLABS_MODEL=eleven_turbo_v2_5
